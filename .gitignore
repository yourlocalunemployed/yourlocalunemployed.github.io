
# Hugo build output — Cloudflare Pages rebuilds this from source on every push,
# so committing it is redundant (and makes noisy diffs / risks a stale copy).
public/
.hugo_build.lock

# local backup archives (stored off-repo, never commit)
blog-backups/
*.tar.gz

# Hugo image-processing cache (regenerated at build)
resources/

# Raw source notes — kept local, not published to the repo
notes/

# Claude Code: local machine-specific settings + write temp files stay local;
# the shared project config (.claude/settings.json) and hooks ARE committed.
.claude/settings.local.json
.claude/*.tmp.*
